    {
      "parameters": {
        "jsCode": "// Step: JSON Format processing\n// LangChain nodes return result in .text property\nconst aiResponse = $node[\"AI Analyzing\"].json.text;\nlet cleanData = aiResponse.trim();\nif (cleanData.startsWith('```json')) {\n  cleanData = cleanData.replace(/^```json/, '');\n}\nif (cleanData.startsWith('```')) {\n  cleanData = cleanData.replace(/^```/, '');\n}\nif (cleanData.endsWith('```')) {\n  cleanData = cleanData.replace(/```$/, '');\n}\ncleanData = cleanData.trim();\n\nconst questions = JSON.parse(cleanData);\n\n// We return A SINGLE ITEM containing the full array of questions.\n// This ensures n8n sends the entire array in one webhook response body.\nreturn [{ json: { questions } }];"
      },
