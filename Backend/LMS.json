      "parameters": {
        "promptType": "define",
        "text": "=System: You are a quiz generator. You MUST return ONLY a raw JSON array. Do not use markdown tables.\n\nUser: Generate {{ $json.body.questionCount || 5 }} MCQ questions based on this text: {{ $json.body.context }}. \nDifficulty: {{ $json.body.difficulty }}.\nRequired Format: \n[\n  {\n    \"questionText\": \"...\",\n    \"questionType\": \"mcq-single\",\n    \"options\": [\n      { \"text\": \"...\", \"isCorrect\": true },\n      { \"text\": \"...\", \"isCorrect\": false },\n      { \"text\": \"...\", \"isCorrect\": false },\n      { \"text\": \"...\", \"isCorrect\": false }\n    ],\n    \"explanation\": \"...\"\n  }\n]",
        "batching": {}
      },
      "id": "e6edcd26-32ba-4146-b308-50adf597b1b9",
      "name": "AI Analyzing",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
